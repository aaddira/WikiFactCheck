# Flask Configuration
FLASK_APP=main.py
FLASK_DEBUG=false
SECRET_KEY=your-secret-key-change-in-production

# Database (PostgreSQL)
# Format: postgresql://username:password@host:port/dbname
# Example (Railway): postgresql://postgres:password@db.example.railway.internal:5432/railway
DATABASE_URL=postgresql://postgres:password@localhost:5432/annotation_platform

# Email Configuration
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@wikifactcheck.com

# Application URLs
APP_URL=http://localhost:5000

# Admin Access
ADMIN_SECRET_TOKEN=your-secret-admin-token-here

# Session Security
SESSION_COOKIE_SECURE=false
# Set to true in production with HTTPS (only send cookies over HTTPS connections)

# Annotation Configuration (optional, has defaults)
ANNOTATORS_PER_SAMPLE=3
MIN_SAMPLES_FOR_TARGET=300
ANNOTATOR_CAP_ENABLED=true
DOMAIN_DISTRIBUTION={"medicine": 50, "history": 30, "animals": 15, "artists": 5}
