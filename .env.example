# Flask Configuration
FLASK_APP=main.py
FLASK_DEBUG=false
SECRET_KEY=your-secret-key-change-in-production

# Database
DATABASE_URL=sqlite:////data/app.db
# Alternative: DB_PATH=/data/app.db (falls back to local dev path if both unset)

# Email Configuration
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@wikifactcheck.com

# Application URLs
APP_URL=http://localhost:5000

# Admin Access
ADMIN_SECRET_TOKEN=your-secret-admin-token-here

# Session Security
SESSION_COOKIE_SECURE=False
# Set to True in production with HTTPS

# Annotation Configuration (optional, has defaults)
ANNOTATORS_PER_SAMPLE=3
MIN_SAMPLES_FOR_TARGET=300
ANNOTATOR_CAP_ENABLED=true
DOMAIN_DISTRIBUTION={"medicine": 50, "history": 30, "animals": 15, "artists": 5}
