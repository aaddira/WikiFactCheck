# Flask configuration
FLASK_APP=main.py
FLASK_DEBUG=false
FLASK_ENV=production

# Database configuration
# Railway: uses /data mount (after volume configured): DATABASE_URL=sqlite:////data/app.db
# Default/working: DATABASE_URL=sqlite:////app/data/app.db (in container ephemeral storage)
# Local dev: omit DATABASE_URL to use relative ./data/app.db path
DATABASE_URL=sqlite:////app/data/app.db

# Security
SECRET_KEY=your-secret-key-change-this-in-production
SESSION_COOKIE_SECURE=false

# Admin authentication
ADMIN_EMAILS=aaddira@gmail.com
ADMIN_SECRET_TOKEN=your-admin-secret-token

# Email configuration
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@wikifactcheck.com

# Application
APP_URL=http://localhost:5000
